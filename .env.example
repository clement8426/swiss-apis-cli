# Copy this file to `.env` in the directory from which you run `swiss`
# (the CLI loads `.env` from the current working directory only).
#
# Leave a variable empty if you do not use the related commands.
# Obtain real credentials only from the official portals linked below.

# OpenTransportData — GTFS real-time feeds (swiss_transport_gtfs_realtime)
# https://api-manager.opentransportdata.swiss/
OTD_API_KEY=

# ZEFIX — Swiss commercial register (swiss_company_*)
# https://www.zefix.admin.ch
ZEFIX_USER=
ZEFIX_PASS=

# FoodRepo — Swiss food products API (swiss_food_search_products)
# https://www.foodrepo.org
FOODREPO_API_KEY=
